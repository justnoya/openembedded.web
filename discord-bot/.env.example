# ─────────────────────────────────────────────────────────────────────────────
# OpenEmbedded Bot — Environment Variables
# Copy this file to .env and fill in your values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token (Bot tab in the Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Your Discord application / client ID (General Information in the Dev Portal)
DISCORD_CLIENT_ID=your_client_id_here

# PostgreSQL connection string — same database your backend uses.
# The bot reads the button_actions table to handle component interactions.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@host:5432/openembedded

# ── Optional ──────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error  (default: info)
BOT_LOG_LEVEL=info

# How often (ms) to re-sync button actions from the database (default: 60000)
# Set to 0 to disable periodic sync (bot loads once on startup only).
DB_SYNC_INTERVAL=60000
