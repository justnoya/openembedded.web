{
  "version": 2,
  "buildCommand": "SDK_DIR=$(pwd) && tsc && vite build && cd .. && yarn workspace website build && cp -r website/dist \"$SDK_DIR/dist-web\"",
  "outputDirectory": "dist-web",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
